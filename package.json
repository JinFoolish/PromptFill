{
  "name": "concept-art-prompt-generator",
  "private": true,
  "version": "0.6.5",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:open": "vite --host --open",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "backend:dev": "cd backend && go run -tags web web_main.go api_server.go config_service.go dashscope_provider.go error_handler.go example_provider.go handlers.go image_service.go interfaces.go types.go adapter_registry.go",
    "backend:build": "cd backend && go build -o ../build/backend .",
    "desktop:dev": "wails dev",
    "desktop:build": "wails build",
    "web:dev": "concurrently \"npm run backend:dev\" \"npm run dev\"",
    "web:build": "npm run backend:build && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.544.0",
    "pako": "^2.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.1",
    "shadcn": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "vitest": "^4.0.16"
  }
}
